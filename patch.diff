         if ! echo "$route" | grep -q 'dev wt0'; then
           echo "::error::NetBird route to cache.kleinbem.dev is not via wt0 — bailing before the build."
           sudo netbird status || true
           exit 1
         fi
+        
+        echo "Waiting for NetBird peer connectivity to cache.kleinbem.dev..."
+        for i in {1..15}; do
+          if ping -c 1 -W 1 cache.kleinbem.dev &>/dev/null; then
+            echo "Connectivity established."
+            break
+          fi
+          sleep 2
+        done
