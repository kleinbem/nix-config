# System Control Center — personal/OS operations.
#
# Invoked as `os <recipe>` via the shell alias. Workspace concerns
# (dev, deployment, jj) live in the meta-workspace justfile under
# ~/Develop/github.com/kleinbem/nix.

# Path to the configuration flake.
FLAKE_PATH := "~/Develop/github.com/kleinbem/nix/nix-config"

[group("Main")]
default:
    @just --list --justfile ~/.justfile

# --- AI services (system) ---

# Start the local AI stack (Ollama, LiteLLM, ComfyUI, Langflow, Langfuse, WebUI, n8n).
[group("AI")]
ai-up:
    sudo systemctl start ollama.service container@litellm.service podman-comfyui.service podman-langflow.service container@langfuse.service container@langfuse-db.service container@open-webui.service container@n8n.service

# Stop the local AI stack.
[group("AI")]
ai-down:
    sudo systemctl stop ollama.service container@litellm.service podman-comfyui.service podman-langflow.service container@langfuse.service container@langfuse-db.service container@open-webui.service container@n8n.service

# Status snapshot of the local AI stack.
[group("AI")]
ai-status:
    systemctl status ollama.service container@litellm.service podman-comfyui.service podman-langflow.service container@langfuse.service container@langfuse-db.service container@open-webui.service container@n8n.service

# Follow logs from the local AI stack.
[group("AI")]
ai-logs:
    journalctl -u ollama.service -u container@litellm.service -u podman-comfyui.service -u podman-langflow.service -u container@langfuse.service -u container@langfuse-db.service -u container@open-webui.service -u container@n8n.service -f

# --- Generic service control ---

[group("Service")]
start service:
    sudo systemctl start {{service}}

[group("Service")]
stop service:
    sudo systemctl stop {{service}}

[group("Service")]
restart service:
    sudo systemctl restart {{service}}

[group("Service")]
status service:
    systemctl status {{service}}

# --- System management ---

# Rebuild + activate the system configuration.
[group("System")]
rebuild:
    nh os switch --ask --diff always {{FLAKE_PATH}}

# Smart rebuild — checks build count first to skip no-op rebuilds.
[group("System")]
rebuild-smart:
    {{FLAKE_PATH}}/scripts/smart-switch.sh {{FLAKE_PATH}}

# Roll back to the previous system generation.
[group("System")]
rollback:
    nh os switch --rollback {{FLAKE_PATH}}

# Show generation history.
[group("System")]
history:
    nix profile history --profile /nix/var/nix/profiles/system

# Diff the closures between the booted and current system.
[group("System")]
changelogs:
    nix store diff-closures /run/booted-system /run/current-system

# Reboot into the BIOS/UEFI firmware setup.
[group("System")]
bios:
    systemctl reboot --firmware-setup

# Verify Nix store integrity.
[group("System")]
verify-store:
    nix-store --verify --check-contents

# Garbage-collect the Nix store + prune old system generations.
[group("System")]
clean:
    nh clean all
    sudo nix-collect-garbage --delete-older-than 3d

# --- Logs ---

# Follow the live journal.
[group("Logs")]
logs:
    journalctl -f

# Show all messages from the current boot.
[group("Logs")]
logs-this-boot:
    journalctl -b 0 --no-hostname

# Show all messages from the previous boot.
[group("Logs")]
logs-last-boot:
    journalctl -b -1 --no-hostname

# --- Diagnostics ---

# Run a 1-minute CPU benchmark.
[group("Diagnostics")]
benchmark:
    @echo "🚀 Running a 1 minute system benchmark..."
    stress-ng --matrix 0 -t 1m --times

# Show BIOS / motherboard info.
[group("Diagnostics")]
bios-info:
    @echo "🖥️  Hardware Information:"
    @sudo bash -c 'echo "Manufacturer: $(dmidecode -s baseboard-manufacturer)"; echo "Product Name: $(dmidecode -s baseboard-product-name)"; echo "Version: $(dmidecode -s bios-version)"; echo "Release Date: $(dmidecode -s bios-release-date)"'

# --- Fixes ---

# Fix YubiKey/Smartcard issues (restart PCSCD & agents).
[group("Fixes")]
fix-yubikey:
    pkill lxqt-openssh-askpass || true
    gpgconf --kill gpg-agent || true
    sudo systemctl restart pcscd

# Fix Chrome — restart shell + Chrome + YubiKey agents.
[group("Fixes")]
fix-chrome:
    pkill -f gnome-shell || true
    pkill -f google-chrome || true
    just fix-yubikey
    google-chrome-stable > /dev/null 2>&1 &

# --- Developer Experience (Distrobox) ---

# Create a Fedora development distrobox.
[group("DX")]
dx-create-fedora name="fedora-dev":
    distrobox create --image registry.fedoraproject.org/fedora:40 --name {{name}}

# Create an Ubuntu development distrobox.
[group("DX")]
dx-create-ubuntu name="ubuntu-dev":
    distrobox create --image ubuntu:24.04 --name {{name}}

# Enter a distrobox.
[group("DX")]
dx-enter name="fedora-dev":
    distrobox enter {{name}}

# List all distroboxes.
[group("DX")]
dx-list:
    distrobox list

# Update all distroboxes.
[group("DX")]
dx-update:
    distrobox upgrade --all

# --- Notes / Obsidian ---

# Append a quick note to the Obsidian Inbox.
[group("Notes")]
note message="":
    @echo "📝 Capturing note..."
    @echo "- [ ] {{message}} (Captured on $(date))" >> $HOME/Documents/Notes/Inbox.md

# Launch Obsidian in the background.
[group("Notes")]
obsidian:
    @obsidian &

# Run the Obsidian vault housekeeping script.
[group("Notes")]
notes-organize:
    @bash ~/Develop/github.com/kleinbem/nix/scripts/organize-notes.sh

# Vault integrity check.
[group("Notes")]
notes-check:
    @echo "🏠 Checking vault integrity..."
    @bash ~/Develop/github.com/kleinbem/nix/scripts/vault-health.sh

# Symlink the workspace docs/ into Obsidian's Notes tree.
[group("Notes")]
notes-link-docs:
    @echo "🔗 Linking workspace docs into Obsidian..."
    @ln -sf ~/Develop/github.com/kleinbem/nix/docs $HOME/Documents/Notes/Project-Docs

# --- Browser maintenance ---

# Delete all Firefox profile folders that aren't the 'standard' one.
[group("Cleanup")]
[confirm("🦊 Delete all Firefox profile folders that aren't 'standard'?")]
clean-browsers:
    @echo "🦊 Cleaning browser profiles..."
    @find ~/.mozilla/firefox -maxdepth 1 -type d -name "*.default*" -not -path "*standard*" -delete

# Reset the Firefox 'laboratory' profile to a clean slate.
[group("Cleanup")]
[confirm("🧪 Reset the Firefox Laboratory profile? All data in that profile will be lost.")]
reset-firefox-laboratory:
    @echo "🧪 Resetting Laboratory profile..."
    @rm -rf ~/.mozilla/firefox/*.laboratory
    @firefox -P laboratory --headless &
    @sleep 3
    @pkill firefox
